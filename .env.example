# Resend — email delivery for the contact form
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile — server-side secret (never expose to browser)
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile — client-side site key (safe to expose, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
